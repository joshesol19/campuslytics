<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Select Month - Monthly Analysis</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-light bg-white shadow-sm border-bottom">
    <div class="container d-flex justify-content-between">
      <a href="/displayDeposits" class="navbar-brand">CampusLytics</a>
      <div class="d-flex gap-2">
        <form action="/displayDeposits" method="get">
          <button class="btn btn-outline-secondary btn-sm" type="submit">Back to Deposits</button>
        </form>
      </div>
    </div>
  </nav>

  <div class="container mt-5">
    <div class="col-12 col-md-6 mx-auto">
      <div class="card p-4">
        <h2 class="h5 mb-3 text-center">Monthly Spending Analysis</h2>
        <p class="text-muted text-center mb-4">
          Choose a month where you have withdrawals and we’ll generate an analysis for that month.
        </p>

        <% if (error_message) { %>
          <div class="alert alert-danger"><%= error_message %></div>
        <% } %>

        <form action="/displayMonthlyAnalysis" method="get" class="row g-3">
          <div class="col-12">
            <label for="month" class="form-label">Month</label>
            <select id="month" name="month" class="form-select" required>
              <option value="">-- Select a month --</option>
              <% (availableMonths || []).forEach(function(m) { %>
                <!-- value format: YYYY-MM -->
                <option value="<%= m.year %>-<%= String(m.month).padStart(2, '0') %>">
                  <%= new Date(m.year, m.month - 1, 1).toLocaleString('en-US', { month: 'long', year: 'numeric' }) %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="col-12 text-center">
            <button type="submit" class="btn btn-primary w-100">View Monthly Analysis</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</body>
</html>

