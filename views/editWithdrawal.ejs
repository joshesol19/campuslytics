<!DOCTYPE html>
 <html lang="en">
 <head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>Edit Withdrawal</title>
   <link rel="icon" type="image/png" href="/images/favicon.png">
 
   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
 
   <style>
    body {
      background-color: #f5f5f5;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .navbar-brand {
      font-weight: 600;
    }

    .role-badge {
      display: inline-flex;
      align-items: center;
      padding: 0.25rem 0.7rem;
      border-radius: 999px;
      font-size: 0.8rem;
      font-weight: 600;
    }

    .role-manager {
      background-color: #fff3cd;
      color: #856404;
    }

    .role-user {
      background-color: #e2e3e5;
      color: #383d41;
    }

    .card {
      border-radius: 14px;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
      border: none;
    }

    .btn-sm {
      padding-inline: 0.6rem;
    }

    .btn-primary {
      background-color: #FF4E00;
      border-color: #FF4E00;
      transition: all .2s ease;
    }

    .btn-primary:hover {
      background-color: #ff7a33;
      border-color: #ff7a33;
      transform: translateY(-2px);
      box-shadow: 0 4px 10px rgba(255, 78, 0, 0.25);
    }
  </style>
 </head>
 
 <body>
 
   <!-- NAVBAR -->
   <nav class="navbar navbar-light bg-white shadow-sm border-bottom">
     <div class="container d-flex justify-content-between">
       <a href="/" class="navbar-brand">CampusLytics</a>
 
       <div class="d-flex gap-2">
         <form action="/" method="get">
           <button class="btn btn-outline-primary btn-sm" type="submit">Home</button>
         </form>
         <form action="/logout" method="get">
           <button class="btn btn-outline-secondary btn-sm" type="submit">Logout</button>
         </form>
       </div>
     </div>
   </nav>
 
   <!-- MAIN CONTENT -->
  <div class="container mt-5">
    <div class="col-12 col-md-7 col-lg-6 mx-auto">
      <div class="card form-card p-4">
        
        <h2 class="mb-3 text-center">Edit Withdrawal (<%=withdrawal.withdrawalDate.toLocaleDateString("en-US", {
         month: "short",
         day: "numeric",
         year: "numeric"
       }) %>)</h2>
        <p class="text-muted text-center mb-4">Enter the details for this withdrawal.</p>

        <% if (error_message) { %>
        <div class="alert alert-danger">
          <%= error_message %>
        </div>
        <% } %>

        <form action="/editWithdrawal/<%=withdrawal.withdrawalID%>/<%=withdrawal.depositID%>" method="post" class="row g-3">

          <div class="col-md-6">
            <label for="date" class="form-label">Date</label>
            <input type="date" class="form-control" id="date" name="date" required value="<%= new Date(withdrawal.withdrawalDate).toISOString().slice(0,10) %>">
          </div>

          <div class="col-md-6">
            <label for="cost" class="form-label">Cost ($)</label>
            <input type="number" class="form-control" id="cost" name="cost" step="0.01" required value="<%=withdrawal.cost%>">
          </div>

          <div class="col-md-6">
            <label for="categorySelect" class="form-label">Category</label>
            <select id="categorySelect" class="form-select">
              <% if ((categoryOptions || []).length === 0) { %>
                <option value="<%=withdrawal.category%>" selected><%=withdrawal.category%></option>
              <% } else { %>
                <option value="">-- Select previous or choose custom --</option>
                <% (categoryOptions || []).forEach(function(opt){ %>
                  <option value="<%= opt %>" <%= opt === withdrawal.category ? 'selected' : '' %>><%= opt %></option>
                <% }) %>
              <% } %>
              <option value="_custom">+ Custom category...</option>
            </select>
            <input
              type="text"
              id="category"
              name="category"
              class="form-control mt-2"
              placeholder="Type category"
              value="<%=withdrawal.category%>"
              required
            >
          </div>

          <div class="col-md-6">
            <label for="subcategorySelect" class="form-label">Subcategory (Company / Entity)</label>
            <select id="subcategorySelect" class="form-select">
              <% if ((subcategoryOptions || []).length === 0) { %>
                <option value="<%=withdrawal.subcategory%>" selected><%=withdrawal.subcategory%></option>
              <% } else { %>
                <option value="">-- Select previous or choose custom --</option>
                <% (subcategoryOptions || []).forEach(function(opt){ %>
                  <option value="<%= opt %>" <%= opt === withdrawal.subcategory ? 'selected' : '' %>><%= opt %></option>
                <% }) %>
              <% } %>
              <option value="_custom">+ Custom subcategory...</option>
            </select>
            <input
              type="text"
              id="subcategory"
              name="subcategory"
              class="form-control mt-2"
              placeholder="Type subcategory / entity"
              value="<%=withdrawal.subcategory%>"
              required
            >
          </div>

          <div class="col-md-12">
            <label for="location" class="form-label">Location</label>
            <input type="text" id="location" name="location" class="form-control" required value="<%=withdrawal.location%>">
          </div>

          <div class="col-md-12">
            <label for="notes" class="form-label">Notes (optional)</label>
            <textarea id="notes" name="notes" class="form-control" rows="2" value="<%=withdrawal.notes%>"></textarea>
          </div>

          <div class="col-md-12">
            <label class="form-label d-block">Was it Online?</label>

            <div class="form-check form-check-inline">
              <input type="radio" id="onlineYes" class="form-check-input" name="onlineFlag" value="1" required>
              <label for="onlineYes" class="form-check-label">Yes</label>
            </div>

            <div class="form-check form-check-inline">
              <input type="radio" id="onlineNo" class="form-check-input" name="onlineFlag" value="0" required>
              <label for="onlineNo" class="form-check-label">No</label>
            </div>
          </div>

          <div class="col-12 text-center">
            <button type="submit" class="btn btn-primary w-100 mt-3">Save Withdrawal</button>
          </div>

        </form>
      </div>
    </div>
  </div>

 <script>
   (function () {
     const catSelect = document.getElementById('categorySelect');
     const catInput  = document.getElementById('category');
     const subSelect = document.getElementById('subcategorySelect');
     const subInput  = document.getElementById('subcategory');

     if (catSelect && catInput) {
       catSelect.addEventListener('change', function () {
         if (this.value && this.value !== '_custom') {
           catInput.value = this.value;
           catInput.readOnly = true;
         } else {
           catInput.readOnly = false;
           if (this.value === '_custom') {
             catInput.value = '';
             catInput.focus();
           }
         }
       });
       catSelect.dispatchEvent(new Event('change'));
     }

     if (subSelect && subInput) {
       subSelect.addEventListener('change', function () {
         if (this.value && this.value !== '_custom') {
           subInput.value = this.value;
           subInput.readOnly = true;
         } else {
           subInput.readOnly = false;
           if (this.value === '_custom') {
             subInput.value = '';
             subInput.focus();
           }
         }
       });
       subSelect.dispatchEvent(new Event('change'));
     }
   })();
 </script>

 </body>
 </html>
 